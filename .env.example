# AccessSentinel Environment Configuration
# Copy this file to .env and fill in values

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/accesssentinel.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501

# Rate Limiting
SCAN_RATE_LIMIT=30/minute
GENERAL_RATE_LIMIT=100/minute

# File Upload
MAX_UPLOAD_SIZE_MB=10

# Model Settings
MODEL_CACHE_DIR=models/
BASELINE_CACHE_DIR=data/baselines/

# Random Seed for Reproducibility
RANDOM_SEED=42

# Logging
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════
# Identity Provider Integrations (optional)
# ═══════════════════════════════════════════════════════════
# Leave blank to use MOCK data. Fill in to enable LIVE mode.

# Okta
# OKTA_ORG_URL=https://dev-123456.okta.com
# OKTA_API_TOKEN=your-sws-token-here

# Azure AD / Microsoft Graph
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# AWS IAM
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# ═══════════════════════════════════════════════════════════
# DeepSeek LLM — Optional CISO Report Narrative (advisory only)
# ═══════════════════════════════════════════════════════════
# Leave ENABLE_LLM_CISO_SUMMARY unset or "0" to disable.
# Set to "1" to enable AI-assisted advisory narratives in the
# CISO HTML report.  The LLM is advisory-only — it never
# overrides computed scores, tiers, or remediation actions.
# If the API key is missing or the call fails, the report
# falls back to deterministic content without error.

# ENABLE_LLM_CISO_SUMMARY=0
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TIMEOUT_SECONDS=30
